+}
+
+// ── Demo users ────────────────────────────────────────────────────────────────
+
+export function getDemoChildProfile(): ChildProfile {
+  return demoChildProfile;
+}
+
+export function getDemoParentName(): string {
+  return demoParentName;
+}
