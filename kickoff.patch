@@ -0,0 +1,27 @@
+interface ProgressBarProps {
+  value: number; // 0–100
+  className?: string;
+  colorClass?: string;
+}
+
+export default function ProgressBar({
+  value,
+  className = "",
+  colorClass = "bg-accent",
+}: ProgressBarProps) {
+  const clamped = Math.min(100, Math.max(0, value));
+  return (
+    <div
+      className={`w-full h-1.5 bg-border rounded-full overflow-hidden ${className}`}
+      role="progressbar"
+      aria-valuenow={clamped}
+      aria-valuemin={0}
+      aria-valuemax={100}
+    >
+      <div
+        className={`h-full ${colorClass} rounded-full transition-all duration-300`}
+        style={{ width: `${clamped}%` }}
+      />
+    </div>
+  );
+}
diff --git a/src/components/ui/RootsLogo.tsx b/src/components/ui/RootsLogo.tsx
new file mode 100644
index 0000000..db0b370
--- /dev/null
+++ b/src/components/ui/RootsLogo.tsx
@@ -0,0 +1,99 @@
+"use client";
+
+import { useEffect, useRef } from "react";
+
+interface RootsLogoProps {
+  size?: number;
+  className?: string;
+}
+
+/**
+ * Roots brand mark.
+ * Filled with the warm orange gradient; a diagonal highlight sweeps
+ * across it at random intervals.
+ */
+export default function RootsLogo({ size = 64, className = "" }: RootsLogoProps) {
+  const shineRef = useRef<SVGAnimateTransformElement>(null);
+
+  useEffect(() => {
+    if (
+      typeof window !== "undefined" &&
+      window.matchMedia("(prefers-reduced-motion: reduce)").matches
+    ) {
+      return;
+    }
+
+    let timer: number;
+    const trigger = () => {
+      shineRef.current?.beginElement?.();
+      timer = window.setTimeout(trigger, 3000 + Math.random() * 6000); // 3–9s
+    };
+    timer = window.setTimeout(trigger, 1200 + Math.random() * 1800);
+    return () => window.clearTimeout(timer);
+  }, []);
+
+  return (
+    <svg
+      width={size}
+      height={size}
+      viewBox="0 0 600 600"
+      xmlns="http://www.w3.org/2000/svg"
+      className={className}
+      role="img"
+      aria-label="Roots"
+    >
+      <defs>
+        {/* Warm orange fill gradient */}
+        <linearGradient id="rootsBase" x1="0" y1="0" x2="1" y2="1">
+          <stop offset="0%" stopColor="#F4C98E" />
+          <stop offset="32%" stopColor="#E89048" />
+          <stop offset="62%" stopColor="#D2641E" />
+          <stop offset="100%" stopColor="#8A2A0C" />
+        </linearGradient>
+
+        {/* Diagonal shine — a narrow bright band parked off-canvas until swept */}
+        <linearGradient
+          id="rootsShine"
+          x1="0"
+          y1="0"
+          x2="1"
+          y2="1"
+          gradientTransform="translate(-1.3 -1.3)"
+        >
+          <stop offset="0" stopColor="#FFFFFF" stopOpacity="0" />
+          <stop offset="0.42" stopColor="#FFFFFF" stopOpacity="0" />
+          <stop offset="0.5" stopColor="#FFF7EA" stopOpacity="0.9" />
+          <stop offset="0.58" stopColor="#FFFFFF" stopOpacity="0" />
+          <stop offset="1" stopColor="#FFFFFF" stopOpacity="0" />
+          <animateTransform
+            ref={shineRef}
+            attributeName="gradientTransform"
+            type="translate"
+            from="-1.3 -1.3"
+            to="1.3 1.3"
+            dur="0.9s"
+            begin="indefinite"
+            fill="freeze"
+          />
+        </linearGradient>
+
+        {/* Paths defined once, referenced twice (base fill + shine overlay) */}
+        <g
+          id="rootMark"
+          transform="translate(0.000000,600.000000) scale(0.100000,-0.100000)"
